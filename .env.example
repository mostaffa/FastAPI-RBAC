# Local fallback URL (used when POSTGRES_HOST is not overridden by Docker Compose)
DATABASE_URL=postgresql://rbac:123456789@localhost:5432/rbac
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rbac
POSTGRES_PASSWORD=123456789
POSTGRES_DB=rbac
SQLALCHEMY_TRACK_MODIFICATIONS=False
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256
SECRET_KEY=Access_KeyForPROJECT
DEFAULT_USER=admin
DEFAULT_PASSWORD=admin1234567
ADMIN_EMAIL=admin@example.com
NGINX_PORT=8080
