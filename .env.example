# =====================================================================
# Copy to .env and fill in real values:  cp .env.example .env
# Single source of truth for ALL environments (backend + Docker + Vite).
# =====================================================================

# ---------------- Application ----------------
APP_NAME="RPi IoT Gateway"
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ---------------- CORS (comma-separated origins) ----------------
CORS_ORIGINS=http://localhost:5173,https://your-domain.example.com

# ---------------- Database ----------------
# POSTGRES_HOST stays "localhost" for local runs; compose overrides it to the
# "postgres" service name. POSTGRES_* are the source of truth.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rbac
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=rbac
SQLALCHEMY_TRACK_MODIFICATIONS=False
# Optional override for an external DB (wins over POSTGRES_* when set):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ---------------- Connection pooling ----------------
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# ---------------- Security / JWT ----------------
SECRET_KEY=CHANGE_ME_SUPER_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------------- Default seeded admin ----------------
DEFAULT_USER=admin
DEFAULT_PASSWORD=CHANGE_ME
ADMIN_EMAIL=admin@example.com

# ---------------- Seeding / first-run reset ----------------
# Bump to force a full DB reset (drop + re-migrate + reseed) on next start.
# WARNING: changing this WIPES all data in the database.
SEED_VERSION=1

# ---------------- Socket.IO ----------------
SOCKETIO_CORS_ORIGINS=*
SOCKETIO_PATH=/ws

# ---------------- Monitoring intervals (seconds) ----------------
SENSOR_POLL_INTERVAL=1.0
SERVICES_POLL_INTERVAL=5.0

# ---------------- Frontend / nginx ----------------
NGINX_PORT=8088
VITE_SERVER_HOST=react.localhost
VITE_SERVER_PORT=4000
BACKEND_API_BASE_URL=http://fastapi.localhost
BACKEND_PORT=8000
