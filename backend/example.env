# Local fallback URL (used when POSTGRES_HOST is not overridden by Docker Compose)
DATABASE_URL=postgresql://DB_USER:PASSWORD@localhost:5432/DB_NAME
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=DB_USER
POSTGRES_PASSWORD=PASSWORD
POSTGRES_DB=DB_NAME
SQLALCHEMY_TRACK_MODIFICATIONS=False
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256
SECRET_KEY=Access_KeyForPROJECT
DEFAULT_USER=admin
DEFAULT_PASSWORD=admin1234567
ADMIN_EMAIL=admin@example.com